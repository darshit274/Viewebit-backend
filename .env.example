# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=mocktail
DB_DIALECT=mysql

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRE=7d

# Email Configuration (for OTP and notifications)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
EMAIL_SECURE=true
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# Firebase Configuration
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY_ID=your-private-key-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com
FIREBASE_CLIENT_ID=your-client-id
FIREBASE_AUTH_URI=https://accounts.google.com/o/oauth2/auth
FIREBASE_TOKEN_URI=https://oauth2.googleapis.com/token
FIREBASE_AUTH_PROVIDER_X509_CERT_URL=https://www.googleapis.com/oauth2/v1/certs
FIREBASE_CLIENT_X509_CERT_URL=https://www.googleapis.com/robot/v1/metadata/x509/firebase-adminsdk-xxx%40your-project.iam.gserviceaccount.com
FIREBASE_TYPE=service_account

# Server Configuration
PORT=3000
NODE_ENV=development
SERVER_URL=https://mocktaleacademy.com/backend

# Admin Panel Configuration
ADMIN_EMAIL=mocktaleacademy@gmail.com
ADMIN_PASSWORD=mocktale.academy@admin.com

# File Upload Configuration
MAX_FILE_SIZE=10485760
UPLOAD_DIR=uploads/

# PDF upload limit (megabytes). Must be <= nginx client_max_body_size and
# <= the admin panel's VITE_PDF_UPLOAD_MAX_SIZE_MB. Default: 50.
PDF_UPLOAD_MAX_SIZE_MB=50

# Body parser size limit (used by express.json/urlencoded). Should usually
# match PDF_UPLOAD_MAX_SIZE_MB + a small buffer. Accepts a value compatible
# with the `bytes` package, e.g. '50mb'. Default derived from PDF_UPLOAD_MAX_SIZE_MB.
EXPRESS_BODY_LIMIT=50mb

# Server-side request timeout for long-running endpoints like PDF upload (ms).
# Should match nginx proxy_read_timeout / proxy_send_timeout on the proxy side.
# Default: 600000 (10 minutes).
REQUEST_TIMEOUT_MS=600000

# API Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100